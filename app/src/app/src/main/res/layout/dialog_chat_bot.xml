<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="600dp"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chatbot Hỗ Trợ"
        android:textStyle="bold"
        android:textSize="18sp"
        android:padding="8dp"
        android:gravity="center"
        android:textColor="#138981" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gợi ý nhanh:"
        android:textSize="12sp"
        android:paddingStart="8dp"
        android:textColor="#757575"
        android:layout_marginTop="8dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/layoutChatSuggestions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <Button
                android:id="@+id/btnChatSuggestSearch"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tìm kiếm món ăn"
                android:layout_marginEnd="8dp"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnChatSuggestBestSeller"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Món ăn bán chạy"
                android:layout_marginEnd="8dp"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnChatSuggestPrice"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Món đắt/Rẻ nhất"
                android:layout_marginEnd="8dp"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnChatSuggestAddToCart"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hướng dẫn đặt món"
                android:textSize="11sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/layoutChatInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="@drawable/bg_edit_text">

        <EditText
            android:id="@+id/edtChatMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Nhập nội dung..."
            android:padding="10dp"
            android:textSize="14sp"
            android:maxLines="3" />

        <ImageButton
            android:id="@+id/btnSendChat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#138981" />
    </LinearLayout>
</LinearLayout>
