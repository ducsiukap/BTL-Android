<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="72dp"
    android:layout_height="72dp"
    android:layout_marginEnd="8dp">

    <ImageView
        android:id="@+id/ivSelectedImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/product_image_placeholder" />

    <ImageButton
        android:id="@+id/btnRemoveSelectedImage"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_action_icon_button"
        android:contentDescription="@string/common_delete"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@color/brand_error" />
</FrameLayout>
