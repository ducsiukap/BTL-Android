<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUserEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvUserRole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="start"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnResetPasswordUser"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_action_icon_button"
            android:contentDescription="@string/common_reset_password"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_rotate"
            android:tint="#138981" />

        <ImageButton
            android:id="@+id/btnEditUser"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_action_icon_button"
            android:contentDescription="@string/common_edit"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="#138981" />

        <ImageButton
            android:id="@+id/btnDeleteUser"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_action_icon_button"
            android:contentDescription="@string/common_delete"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#138981" />
    </LinearLayout>
</LinearLayout>
