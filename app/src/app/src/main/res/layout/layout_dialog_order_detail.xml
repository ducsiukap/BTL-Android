<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="24dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvDialogOrderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chi tiết đơn hàng"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="@color/brand_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogOrderCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvDialogOrderTitle"
            android:layout_marginTop="4dp"
            android:text="#ORDER123"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="#888888" />

        <TextView
            android:id="@+id/tvDialogOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_order_status_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="ĐANG CHẾ BIẾN"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="#F0F0F0" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Sản phẩm"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="@color/brand_text_primary"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layoutDialogOrderItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">
        <!-- item_dialog_order_detail will be inflated here -->
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="#F0F0F0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tổng thanh toán"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="@color/brand_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogOrderTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="114.000đ"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="@color/brand_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogOrderClose"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="24dp"
        android:text="ĐÓNG"
        app:cornerRadius="12dp" />

</LinearLayout>
