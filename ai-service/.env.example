# ===== LLM Provider Configuration =====
# Provider: "openrouter" or "ollama"
LLM_PROVIDER=ollama

# OpenRouter settings
OPENROUTER_API_KEY=disabled-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o

# Ollama settings
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=kimi-k2

# ===== ASR Text Correction =====
# A lighter/cheaper model for post-ASR text correction
CORRECTION_LLM_PROVIDER=ollama
CORRECTION_MODEL=kimi-k2

# ===== Voice Activity Detection =====
# Enable/disable Silero VAD (filters silence before ASR)
VAD_ENABLED=true

# ===== Model Cache =====
# Where HuggingFace models (ChunkFormer, etc.) are stored
# Default: ~/.cache/huggingface/hub
# Set this if you want models in a specific location
HF_HOME=

# Where torch hub models are stored (Silero VAD cache)
# Default: ~/.cache/torch
TORCH_HOME=

# ===== Runtime Tuning =====
# Number of ASR worker threads
ASR_MAX_WORKERS=4

# In-memory cart expiration (seconds)
CART_TTL_SECONDS=3600

# Preload speech models at startup (faster first request, slower boot)
MODEL_PRELOAD_ON_STARTUP=false

# App log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Application timezone for date/time presentation
APP_TIMEZONE=Asia/Ho_Chi_Minh

# ===== Database (MySQL) =====
# Keep DB_PASSWORD as placeholder, do not commit real secrets.
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ===== Server Configuration =====
HOST=0.0.0.0
PORT=8000
